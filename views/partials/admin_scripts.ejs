<link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css">

<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>

<script>
    $(document).ready(function () {
        // 1. HГ m bб»Ҹ dбәҘu tiбәҝng Viб»Үt
        function removeVietnameseTones(str) {
            if (!str) return "";
            str = str.replace(/Г |ГЎ|бәЎ|бәЈ|ГЈ|Гў|бә§|бәҘ|бәӯ|бә©|бә«|Дғ|бәұ|бәҜ|бә·|бәі|бәө/g, "a").replace(/ГЁ|Г©|бә№|бә»|бәҪ|ГӘ|б»Ғ|бәҝ|б»Ү|б»ғ|б»…/g, "e")
                .replace(/Г¬|Гӯ|б»Ӣ|б»ү|Д©/g, "i").replace(/ГІ|Гі|б»Қ|б»Ҹ|Гө|Гҙ|б»“|б»‘|б»ҷ|б»•|б»—|ЖЎ|б»қ|б»ӣ|б»Ј|б»ҹ|б»Ў/g, "o")
                .replace(/Г№|Гә|б»Ҙ|б»§|Е©|Ж°|б»«|б»©|б»ұ|б»ӯ|б»Ҝ/g, "u").replace(/б»і|ГҪ|б»ө|б»·|б»№/g, "y").replace(/Д‘/g, "d")
                .replace(/ГҖ|ГҒ|бә |бәў|Гғ|ГӮ|бәҰ|бәӨ|бә¬|бәЁ|бәӘ|ДӮ|бә°|бә®|бә¶|бәІ|бәҙ/g, "A").replace(/ГҲ|Гү|бәё|бәә|бәј|ГҠ|б»Җ|бәҫ|б»Ҷ|б»Ӯ|б»„/g, "E")
                .replace(/ГҢ|ГҚ|б»Ҡ|б»Ҳ|ДЁ/g, "I").replace(/Г’|Г“|б»Ң|б»Һ|Г•|Г”|б»’|б»җ|б»ҳ|б»”|б»–|Ж |б»ң|б»ҡ|б»ў|б»һ|б» /g, "O")
                .replace(/Гҷ|Гҡ|б»Ө|б»Ұ|ЕЁ|ЖҜ|б»Ә|б»Ё|б»°|б»¬|б»®/g, "U").replace(/б»І|Гқ|б»ҙ|б»¶|б»ё/g, "Y").replace(/Дҗ/g, "D");
            return str;
        }

        // DбәЎy DataTables tГ¬m kiбәҝm tiбәҝng Viб»Үt (Text thЖ°б»қng & HTML)
        jQuery.fn.DataTable.ext.type.search.string = function (data) {
            return !data ? '' : typeof data === 'string' ? removeVietnameseTones(data).toLowerCase() : data;
        };
        jQuery.fn.DataTable.ext.type.search.html = function (data) {
            return !data ? '' : typeof data === 'string' ? removeVietnameseTones(data.replace(/<.*?>/g, '')).toLowerCase() : data;
        };

        // 2. Khб»ҹi tбәЎo DataTables dГ№ng chung
        if ($('.table-admin').length > 0) {
            const adminTables = $('.table-admin').DataTable({
                "language": { "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json" },
                "columnDefs": [{ "targets": 'no-sort', "searchable": false, "orderable": false }],
                "autoWidth": false,
                "order": [[0, 'desc']],
                // CбәҘu trГәc DOM: B (NГәt bбәҘm), f (TГ¬m kiбәҝm), r (Processing), t (Table), i (Info), p (PhГўn trang)
                "dom": '<"d-flex justify-content-between align-items-center mb-3"Bf>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                "buttons": [
                    {
                        extend: 'excelHtml5',
                        text: '<i class="bi bi-file-earmark-excel me-1"></i> XuбәҘt Excel',
                        className: 'btn btn-success btn-sm rounded-pill px-3 shadow-sm',
                        title: 'BГЎo cГЎo hб»Ү thб»‘ng NoliCinema - ' + new Date().toLocaleDateString('vi-VN'),
                        exportOptions: {
                            columns: ':not(.no-sort)'
                        }
                    }
                ]
            });

            // 3. Tб»ұ Д‘б»ҷng Д‘ГЎnh sб»‘ STT (Chб»ү ГЎp dб»Ҙng nбәҝu cб»ҷt Д‘бә§u tiГӘn Duy muб»‘n lГ m STT nhбәЈy sб»‘)
            // Nбәҝu Duy muб»‘n giб»Ҝ MГЈ HДҗ gб»‘c thГ¬ cГі thб»ғ comment Д‘oбәЎn nГ y lбәЎi
            adminTables.on('order.dt search.dt', function () {
                let i = 1;
                adminTables.cells(null, 0, { search: 'applied', order: 'applied' }).every(function (cell) {
                    this.data(i++);
                });
            }).draw();
        }
    });
</script>