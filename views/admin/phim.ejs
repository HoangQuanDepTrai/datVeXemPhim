<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <link rel="stylesheet" href="/css/admin_dashboard.css">
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
        <title>Quản lý Phim - Admin Duy Movie</title>
        <style>
            .img-preview {
                width: 50px;
                height: 75px;
                object-fit: cover;
                border-radius: 5px;
            }
        </style>
</head>

<body>
    <%- include('../partials/admin_sidebar') %>
        <div class="main-content">
            <div class="top-nav">
                <h4 class="fw-bold mb-0">Hệ thống / <small class="text-muted">Quản lý Phim</small></h4>
            </div>
            <div class="card border-0 shadow-sm p-4 rounded-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-film"></i> Danh Sách Phim</h4>
                    <button class="btn btn-danger rounded-pill px-4" data-bs-toggle="modal"
                        data-bs-target="#modalAddPhim">
                        <i class="bi bi-plus-circle"></i> Thêm Phim Mới
                    </button>
                </div>
                <div class="table-responsive">
                    <table id="tablePhim" class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th class="text-center">STT</th>
                                <th>Ảnh</th>
                                <th>Tên Phim</th>
                                <th>Thể Loại</th>
                                <th>Thời Lượng</th>
                                <th class="text-center">Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% phims.forEach(p=> { %>
                                <tr>
                                    <td class="text-center fw-bold"></td>
                                    <td><img src="<%= p.HINH_ANH_POSTER %>" class="img-preview"></td>
                                    <td>
                                        <div class="fw-bold">
                                            <%= p.TEN_PHIM %>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-info text-dark">
                                            <%= p.TEN_THE_LOAI || 'N/A' %>
                                        </span></td>
                                    <td>
                                        <%= p.THOI_LUONG_PHIM %> phút
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger"
                                            onclick="confirmHide('<%= p.MA_PHIM %>')">Ẩn</button>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Modal Thêm Phim -->
        <!-- Modal Thêm Phim -->
        <div class="modal fade" id="modalAddPhim" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg border-0">
                <div class="modal-content rounded-4 shadow">
                    <div class="modal-header border-0">
                        <h5 class="modal-title fw-bold text-primary">
                            <i class="bi bi-plus-circle me-2"></i>Thêm Phim Mới
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>

                    <!-- Form xử lý - Nhớ enctype để upload được file -->
                    <form id="formAddPhim" enctype="multipart/form-data">
                        <div class="modal-body">
                            <div class="row g-3">
                                <div class="col-md-8">
                                    <label class="form-label fw-bold small text-muted">Tên Phim *</label>
                                    <input type="text" name="ten" class="form-control rounded-3" required
                                        placeholder="Nhập tên phim">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small text-muted">Thể Loại Phim *</label>
                                    <select name="maTL" class="form-select rounded-3" required>
                                        <option value="" selected disabled>-- Chọn thể loại --</option>
                                        <% theLoais.forEach(tl=> { %>
                                            <option value="<%= tl.MA_THE_LOAI %>">
                                                <%= tl.TEN_THE_LOAI %>
                                            </option>
                                            <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-8">
                                    <label class="form-label fw-bold small text-muted">URL Trailer) *</label>
                                    <input type="text" name="trailer" class="form-control rounded-3" required>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small text-muted">Thời lượng *</label>
                                    <input type="number" name="thoiluong" class="form-control rounded-3" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-muted">Đạo Diễn *</label>
                                    <input type="text" name="daodien" class="form-control rounded-3" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small text-muted">Giới hạn tuổi *</label>
                                    <input type="number" name="tuoi" class="form-control rounded-3" required>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small text-muted">Diễn Viên *</label>
                                    <input type="text" name="dienvien" class="form-control rounded-3" required
                                        placeholder="Tên các diễn viên...">
                                </div>

                                <!-- CHỖ NÀY ĐÃ ĐƯỢC ĐỔI SANG CHỌN FILE -->
                                <div class="row g-3">
                                    <!-- Phần Poster -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Poster Phim (Ảnh dọc)
                                            *</label>
                                        <input type="text" name="posterLink" class="form-control rounded-3 mb-2"
                                            placeholder="Dán URL ảnh vào đây...">
                                        <div class="text-center small text-muted mb-2">- HOẶC -</div>
                                        <input type="file" name="posterFile" class="form-control rounded-3"
                                            accept="image/*">
                                    </div>

                                    <!-- Phần Ảnh Nền -->
                                    <div class="col-md-6">
                                        <label class="form-label fw-bold small text-muted">Ảnh Nền (Ảnh ngang) *</label>
                                        <input type="text" name="nenLink" class="form-control rounded-3 mb-2"
                                            placeholder="Dán URL ảnh vào đây...">
                                        <div class="text-center small text-muted mb-2">- HOẶC -</div>
                                        <input type="file" name="nenFile" class="form-control rounded-3"
                                            accept="image/*">
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small text-muted">Tóm tắt nội dung *</label>
                                    <textarea name="noidung" class="form-control rounded-3" rows="3"
                                        required></textarea>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-light rounded-pill px-4"
                                data-bs-dismiss="modal">Hủy</button>
                            <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">
                                Xác nhận thêm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            $(document).ready(function () {
                // 1. Khởi tạo DataTable cho bảng danh sách phim
                const t = $('#tablePhim').DataTable({
                    "language": {
                        "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json"
                    },
                    "columnDefs": [{
                        "searchable": false,
                        "orderable": false,
                        "targets": 0 // Cột STT không cho search/order
                    }],
                    "order": [[1, 'asc']] // Sắp xếp mặc định theo tên phim
                });

                // 2. Logic tự động đánh STT khi tìm kiếm hoặc chuyển trang
                t.on('order.dt search.dt', function () {
                    let i = 1;
                    t.cells(null, 0, { search: 'applied', order: 'applied' }).every(function (cell) {
                        this.data(i++);
                    });
                }).draw();

                // 3. Xử lý Thêm Phim Mới bằng AJAX (Fetch API)
                const modalAdd = new bootstrap.Modal(document.getElementById('modalAddPhim'));

                $('form[action="/admin/phim/add"]').on('submit', async function (e) {
                    e.preventDefault(); // Ngăn form load lại trang

                    // Hiển thị loading
                    Swal.fire({
                        title: 'Đang xử lý...',
                        text: 'Vui lòng chờ trong giây lát',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading(); }
                    });

                    // Thu thập dữ liệu từ Form
                    const formData = {};
                    $(this).serializeArray().forEach(item => {
                        formData[item.name] = item.value;
                    });

                    try {
                        const response = await fetch('/admin/phim/add', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(formData)
                        });

                        const result = await response.json();

                        if (result.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: result.message || 'Phim mới đã được thêm vào hệ thống.',
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                modalAdd.hide(); // Đóng modal
                                location.reload(); // Load lại trang để cập nhật bảng
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Thất bại!',
                                text: result.message || 'Có lỗi xảy ra khi thêm phim.'
                            });
                        }
                    } catch (error) {
                        console.error("Lỗi kết nối:", error);
                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi kết nối!',
                            text: 'Không thể kết nối tới máy chủ.'
                        });
                    }
                });
            });

            // 4. Hàm xác nhận và xóa phim
            async function confirmHide(id) {
                const confirmResult = await Swal.fire({
                    title: 'Xác nhận ẩn phim?',
                    text: "Phim sẽ bị gỡ khỏi danh sách hiển thị cho khách hàng!",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d82f8b',
                    confirmButtonText: 'Đồng ý ẩn',
                    cancelButtonText: 'Hủy'
                });

                if (confirmResult.isConfirmed) {
                    try {
                        // URL mới: /admin/phim/hide/
                        const response = await fetch('/admin/phim/hide/' + id, {
                            method: 'PUT' // Nếu ở Router Duy dùng router.put
                        });
                        const result = await response.json();

                        if (result.success) {
                            Swal.fire('Thành công!', result.message, 'success')
                                .then(() => location.reload());
                        }
                    } catch (error) {
                        Swal.fire('Lỗi!', 'Không thể kết nối máy chủ!', 'error');
                    }
                }
            }
        </script>
</body>

</html>