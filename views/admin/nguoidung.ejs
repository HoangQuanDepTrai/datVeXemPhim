<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('../partials/head') %>
        <link rel="stylesheet" href="/css/admin_dashboard.css">
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
</head>

<body>
    <%- include('../partials/admin_sidebar') %>
        <div class="main-content">
            <div class="top-nav">
                <h4 class="fw-bold mb-0">Hệ thống / <small class="text-muted">Người Dùng</small></h4>
            </div>
            <div class="card border-0 shadow-sm p-0 rounded-4">
                <table id="tableNguoiDung" class="table table-hover align-middle mb-0 table-admin">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 no-sort">STT</th>
                            <th>Thành viên</th>
                            <th>Số điện thoại</th>
                            <th>Email</th>
                            <th class="text-center">Vai Trò</th>
                            <th class="text-center">Trạng thái</th>
                            <th class="text-center no-sort">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof users !=='undefined' && users && users.length> 0) { %>
                            <% users.forEach(function(user, index) { %>
                                <tr>
                                    <td class="text-center fw-bold text-muted ps-4">
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm me-3"
                                                style="width: 40px; height: 40px; font-size: 1.2rem;">
                                                <%= user.HO_TEN ? user.HO_TEN.charAt(0).toUpperCase() : 'U' %>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold text-dark">
                                                    <%= user.HO_TEN %>
                                                </h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-secondary">
                                        <%= user.SO_DIEN_THOAI %>
                                    </td>
                                    <td class="text-secondary">
                                        <%= user.EMAIL %>
                                    </td>
                                    <td class="text-center">
                                        <% if (user.VAI_TRO && user.VAI_TRO.trim().toLowerCase()==='admin' ) { %>
                                            <span class="badge bg-danger px-3 py-2 rounded-pill shadow-sm">Admin</span>
                                            <% } else { %>
                                                <span class="badge bg-primary px-3 py-2 rounded-pill shadow-sm">Khách
                                                    hàng</span>
                                                <% } %>
                                    </td>
                                    <td class="text-center">
                                        <% if (user.TRANG_THAI !==0) { %>
                                            <span class="text-success fw-bold small"><i
                                                    class="bi bi-check-circle-fill me-1"></i>Hoạt động</span>
                                            <% } else { %>
                                                <span class="text-danger fw-bold small"><i
                                                        class="bi bi-lock-fill me-1"></i>Bị khóa</span>
                                                <% } %>
                                    </td>
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button
                                                class="btn btn-sm btn-light border rounded-pill px-3 dropdown-toggle shadow-sm"
                                                type="button" data-bs-toggle="dropdown">
                                                <i class="bi bi-gear me-1"></i> Tùy chỉnh
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3">
                                                <li>
                                                    <button
                                                        class="dropdown-item py-2 fw-bold btn-khoa-tk <%= user.TRANG_THAI !== 0 ? 'text-danger' : 'text-success' %>"
                                                        data-id="<%= user.MA_NGUOI_DUNG %>"
                                                        data-status="<%= user.TRANG_THAI %>">
                                                        <% if (user.TRANG_THAI !==0) { %>
                                                            <i class="bi bi-lock-fill text-danger me-2"></i> Khóa tài
                                                            khoản
                                                            <% } else { %>
                                                                <i class="bi bi-unlock-fill text-success me-2"></i> Mở
                                                                khóa tài khoản
                                                                <% } %>
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">Chưa có người dùng nào
                                                trên hệ thống hoặc lỗi tải dữ liệu.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <%- include('../partials/admin_scripts') %>
            <script>
                $(document).ready(function () {
                    // Xử lý chức năng KHÓA / MỞ KHÓA
                    $('#tableNguoiDung tbody').on('click', '.btn-khoa-tk', async function () {
                        const id = $(this).data('id');
                        const currentStatus = $(this).data('status');

                        const isLocking = (currentStatus !== 0);
                        const confirmText = isLocking ? "Bạn có chắc muốn KHÓA tài khoản này không?" : "Bạn muốn MỞ KHÓA cho tài khoản này?";
                        const confirmBtnColor = isLocking ? "#dc3545" : "#198754";

                        const result = await Swal.fire({
                            title: 'Xác nhận',
                            text: confirmText,
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonColor: confirmBtnColor,
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Đồng ý',
                            cancelButtonText: 'Hủy'
                        });

                        if (result.isConfirmed) {
                            Swal.fire({ title: 'Đang xử lý...', didOpen: () => Swal.showLoading() });
                            try {
                                const response = await fetch('/admin/nguoidung/khoa-mo', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ id: id, currentStatus: currentStatus })
                                });
                                const data = await response.json();

                                if (data.success) {
                                    Swal.fire('Thành công!', data.message, 'success').then(() => location.reload());
                                } else {
                                    Swal.fire('Lỗi!', data.message, 'error');
                                }
                            } catch (err) {
                                Swal.fire('Lỗi kết nối!', 'Không thể gửi yêu cầu.', 'error');
                            }
                        }
                    });
                });
            </script>
</body>

</html>